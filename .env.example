# Copy this file to ".env" and fill in your own values.
#   Windows  : copy .env.example .env
#   Mac/Linux: cp .env.example .env
# The .env file is ignored by Git, so your real passwords stay private.

# Django
# SECRET_KEY: any long random string. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=put-a-long-random-string-here
DEBUG=True

# MySQL database — change these to match your own MySQL setup
DB_NAME=ecommerce_lab3
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306
